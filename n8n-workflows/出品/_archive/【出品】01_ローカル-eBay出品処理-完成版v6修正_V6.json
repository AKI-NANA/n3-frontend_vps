        "jsCode": "// 商品データを個別アイテムに分割\nconst response = $input.first().json;\nconst products = response.data || [];\nconst baseData = $('リクエスト検証・変数設定').item.json;\n\nif (products.length === 0) {\n  return [{ json: { noProducts: true, ...baseData } }];\n}\n\nreturn products.map(product => ({\n  json: {\n    ...product,\n    BASE_URL: baseData.BASE_URL,\n    account: baseData.account,\n    requestId: baseData.requestId\n  }\n}));"
      },
