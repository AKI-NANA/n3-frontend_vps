        "jsCode": "// ========================================\n// リクエスト検証・変数設定\n// ========================================\n\n// ベースURL（ローカル/VPS切り替え）\nconst BASE_URL = '{{$env.N3_API_URL}}';\n// VPS用: const BASE_URL = 'http://{{$env.VPS_HOST}}:3000';\n\n// Webhookデータの取得（.bodyのラップ対応）\nconst rawData = $input.first().json;\nlet input = rawData.body || rawData;\n\n// bodyが文字列の場合はパース\nif (typeof input === 'string') {\n  try { input = JSON.parse(input); } catch (e) { input = {}; }\n}\n\n// デバッグログ\nconsole.log('受信データ:', JSON.stringify(input));\n\n// 必須チェック\nif (!input.action) {\n  throw new Error('action フィールドは必須です。受信データ: ' + JSON.stringify(rawData));\n}\n\nconst validActions = ['list_now', 'schedule', 'reserve'];\nif (!validActions.includes(input.action)) {\n  throw new Error('無効なaction: ' + input.action);\n}\n\nconst ids = input.ids || [];\nconst hasItems = ids.length > 0;\n\nreturn [{\n  json: {\n    BASE_URL,\n    action: input.action,\n    ids: ids,\n    account: input.account || 'account1',\n    itemCount: ids.length,\n    hasItems: hasItems,\n    requestId: 'req_' + Date.now(),\n    timestamp: new Date().toISOString(),\n    results: {\n      success: [],\n      failed: [],\n      successCount: 0,\n      failedCount: 0\n    }\n  }\n}];"
      },
